MONGO_URI=mongodb://<db_user>:<db_password>@ac-6fiuemj-shard-00-00.py9zhda.mongodb.net:27017,ac-6fiuemj-shard-00-01.py9zhda.mongodb.net:27017,ac-6fiuemj-shard-00-02.py9zhda.mongodb.net:27017/?ssl=true&replicaSet=atlas-10udbo-shard-0&authSource=admin&appName=vocko
MONGO_DB=vocko
# Thay <db_user> và <db_password> bằng tên người dùng và mật khẩu thực tế của bạn
# Render/cloud: Atlas → Network Access phải cho phép IP của host (thường dùng 0.0.0.0/0 khi test).
# URI nên dùng mongodb+srv://... (Atlas “Connect” → Drivers). Bật tạm SKIP_DB_PING=1 chỉ để kiểm tra process lên port.
# SKIP_DB_PING=

# OpenRouter (hint + chấm điểm gần đúng khi học). Không có key = chỉ so khớp chuỗi, không gợi ý AI.
# Mặc định code: model openrouter/free + header X-OpenRouter-Only-Free (client tự gửi khi model là openrouter/free).
# Đổi sang model trả phí: set OPENROUTER_MODEL_* và OPENROUTER_ONLY_FREE=0 để tắt header only-free.
OPENROUTER_API_KEY=
OPENROUTER_MODEL_HINT=openrouter/free
OPENROUTER_MODEL_GRADE=openrouter/free
# POST /import/toeic-vocab (paste text → TOEIC vocabulary). Empty = same as OPENROUTER_MODEL_HINT.
# OPENROUTER_MODEL_IMPORT=openrouter/free
# Longer timeout per chunk (seconds, clamped 15–180). Default 75.
# OPENROUTER_TIMEOUT_IMPORT=75
# meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_ONLY_FREE=0
# Gợi ý tags (POST /tags/suggest). Nếu không set OPENROUTER_MODEL_TAG, dùng cùng model với OPENROUTER_MODEL_HINT.
# OPENROUTER_MODEL_TAG=openrouter/free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter khuyến nghị HTTP-Referer là URL thật (site/repo); localhost đôi khi gây lỗi từ phía provider.
# OPENROUTER_HTTP_REFERER=https://github.com/youruser/vocko
# OPENROUTER_APP_TITLE=VocKO
